<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#f3f4f6"/>
  <rect x="50" y="50" width="700" height="500" rx="20" fill="white" stroke="#e5e7eb" stroke-width="2"/>
  
  <!-- Header -->
  <rect x="80" y="80" width="640" height="60" rx="10" fill="#f97316" opacity="0.1"/>
  <circle cx="110" cy="110" r="20" fill="#f97316"/>
  <rect x="150" y="95" width="200" height="15" rx="5" fill="#f97316"/>
  <rect x="150" y="120" width="150" height="10" rx="5" fill="#fb923c"/>
  
  <!-- Resume Content -->
  <rect x="80" y="170" width="300" height="12" rx="5" fill="#1f2937"/>
  <rect x="80" y="195" width="250" height="8" rx="4" fill="#6b7280"/>
  <rect x="80" y="210" width="280" height="8" rx="4" fill="#6b7280"/>
  <rect x="80" y="225" width="200" height="8" rx="4" fill="#6b7280"/>
  
  <rect x="80" y="260" width="200" height="12" rx="5" fill="#1f2937"/>
  <rect x="80" y="285" width="320" height="8" rx="4" fill="#6b7280"/>
  <rect x="80" y="300" width="300" height="8" rx="4" fill="#6b7280"/>
  <rect x="80" y="315" width="280" height="8" rx="4" fill="#6b7280"/>
  
  <!-- Project Cards -->
  <rect x="450" y="170" width="270" height="120" rx="10" fill="#fff7ed" stroke="#f97316" stroke-width="2"/>
  <rect x="470" y="190" width="100" height="10" rx="5" fill="#f97316"/>
  <rect x="470" y="210" width="230" height="8" rx="4" fill="#6b7280"/>
  <rect x="470" y="225" width="200" height="8" rx="4" fill="#6b7280"/>
  <rect x="470" y="240" width="220" height="8" rx="4" fill="#6b7280"/>
  <rect x="470" y="260" width="120" height="20" rx="10" fill="#f97316"/>
  <text x="490" y="275" font-family="Arial" font-size="12" fill="white" font-weight="bold">AI MATCHED</text>
  
  <rect x="450" y="310" width="270" height="120" rx="10" fill="#f3f4f6" stroke="#e5e7eb" stroke-width="2"/>
  <rect x="470" y="330" width="100" height="10" rx="5" fill="#9ca3af"/>
  <rect x="470" y="350" width="230" height="8" rx="4" fill="#d1d5db"/>
  <rect x="470" y="365" width="200" height="8" rx="4" fill="#d1d5db"/>
  <rect x="470" y="380" width="220" height="8" rx="4" fill="#d1d5db"/>
  
  <!-- AI Icon -->
  <circle cx="400" cy="500" r="30" fill="#f97316" opacity="0.2"/>
  <text x="385" y="510" font-family="Arial" font-size="24" fill="#f97316">AI</text>
</svg>
