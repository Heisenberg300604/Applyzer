<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#f3f4f6"/>
  <rect x="50" y="50" width="700" height="500" rx="20" fill="white" stroke="#e5e7eb" stroke-width="2"/>
  
  <!-- Dashboard Header -->
  <rect x="80" y="80" width="640" height="50" rx="10" fill="#f97316" opacity="0.1"/>
  <rect x="100" y="95" width="200" height="15" rx="5" fill="#1f2937"/>
  <text x="110" y="108" font-family="Arial" font-size="12" fill="#1f2937" font-weight="bold">Application Tracker</text>
  
  <!-- Stats Cards -->
  <rect x="80" y="160" width="150" height="80" rx="10" fill="#fff7ed" stroke="#f97316" stroke-width="2"/>
  <text x="100" y="185" font-family="Arial" font-size="14" fill="#6b7280">Total Applied</text>
  <text x="100" y="220" font-family="Arial" font-size="32" fill="#f97316" font-weight="bold">45K+</text>
  
  <rect x="250" y="160" width="150" height="80" rx="10" fill="#dcfce7" stroke="#10b981" stroke-width="2"/>
  <text x="270" y="185" font-family="Arial" font-size="14" fill="#6b7280">Reply Rate</text>
  <text x="270" y="220" font-family="Arial" font-size="32" fill="#10b981" font-weight="bold">34%</text>
  
  <rect x="420" y="160" width="150" height="80" rx="10" fill="#dbeafe" stroke="#3b82f6" stroke-width="2"/>
  <text x="440" y="185" font-family="Arial" font-size="14" fill="#6b7280">Active Jobs</text>
  <text x="440" y="220" font-family="Arial" font-size="32" fill="#3b82f6" font-weight="bold">186</text>
  
  <rect x="590" y="160" width="150" height="80" rx="10" fill="#fef3c7" stroke="#f59e0b" stroke-width="2"/>
  <text x="610" y="185" font-family="Arial" font-size="14" fill="#6b7280">Interviews</text>
  <text x="610" y="220" font-family="Arial" font-size="32" fill="#f59e0b" font-weight="bold">2.4K</text>
  
  <!-- Application List -->
  <rect x="80" y="270" width="640" height="50" rx="8" fill="#fafafa" stroke="#e5e7eb" stroke-width="1"/>
  <circle cx="110" cy="295" r="15" fill="#3b82f6"/>
  <text x="105" y="300" font-family="Arial" font-size="12" fill="white" font-weight="bold">G</text>
  <rect x="140" y="280" width="150" height="12" rx="5" fill="#1f2937"/>
  <rect x="140" y="300" width="100" height="8" rx="4" fill="#6b7280"/>
  <rect x="600" y="285" width="100" height="20" rx="10" fill="#10b981"/>
  <text x="620" y="300" font-family="Arial" font-size="10" fill="white" font-weight="bold">REPLIED</text>
  
  <rect x="80" y="335" width="640" height="50" rx="8" fill="#fafafa" stroke="#e5e7eb" stroke-width="1"/>
  <circle cx="110" cy="360" r="15" fill="#8b5cf6"/>
  <text x="105" y="365" font-family="Arial" font-size="12" fill="white" font-weight="bold">S</text>
  <rect x="140" y="345" width="150" height="12" rx="5" fill="#1f2937"/>
  <rect x="140" y="365" width="100" height="8" rx="4" fill="#6b7280"/>
  <rect x="600" y="350" width="100" height="20" rx="10" fill="#f97316"/>
  <text x="625" y="365" font-family="Arial" font-size="10" fill="white" font-weight="bold">SENT</text>
  
  <rect x="80" y="400" width="640" height="50" rx="8" fill="#fafafa" stroke="#e5e7eb" stroke-width="1"/>
  <circle cx="110" cy="425" r="15" fill="#1f2937"/>
  <text x="105" y="430" font-family="Arial" font-size="12" fill="white" font-weight="bold">N</text>
  <rect x="140" y="410" width="150" height="12" rx="5" fill="#1f2937"/>
  <rect x="140" y="430" width="100" height="8" rx="4" fill="#6b7280"/>
  <rect x="600" y="415" width="100" height="20" rx="10" fill="#6b7280"/>
  <text x="620" y="430" font-family="Arial" font-size="10" fill="white" font-weight="bold">PENDING</text>
  
  <!-- Chart Icon -->
  <rect x="80" y="470" width="30" height="40" rx="5" fill="#f97316" opacity="0.3"/>
  <rect x="120" y="450" width="30" height="60" rx="5" fill="#f97316" opacity="0.5"/>
  <rect x="160" y="430" width="30" height="80" rx="5" fill="#f97316"/>
</svg>
