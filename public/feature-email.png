<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#f3f4f6"/>
  <rect x="50" y="50" width="700" height="500" rx="20" fill="white" stroke="#e5e7eb" stroke-width="2"/>
  
  <!-- Gmail Header -->
  <rect x="50" y="50" width="700" height="60" rx="20" fill="#f97316" opacity="0.1"/>
  <circle cx="90" cy="80" r="15" fill="#f97316"/>
  <rect x="120" y="70" width="150" height="12" rx="5" fill="#1f2937"/>
  <rect x="120" y="88" width="100" height="8" rx="4" fill="#6b7280"/>
  
  <!-- Email Compose -->
  <rect x="80" y="140" width="640" height="380" rx="10" fill="#fafafa" stroke="#e5e7eb" stroke-width="1"/>
  
  <!-- To Field -->
  <rect x="100" y="160" width="30" height="10" rx="5" fill="#6b7280"/>
  <rect x="140" y="160" width="200" height="10" rx="5" fill="#e5e7eb"/>
  
  <!-- Subject -->
  <rect x="100" y="190" width="60" height="10" rx="5" fill="#6b7280"/>
  <rect x="170" y="190" width="400" height="10" rx="5" fill="#e5e7eb"/>
  
  <!-- Email Body -->
  <rect x="100" y="230" width="600" height="8" rx="4" fill="#1f2937"/>
  <rect x="100" y="250" width="580" height="8" rx="4" fill="#6b7280"/>
  <rect x="100" y="265" width="600" height="8" rx="4" fill="#6b7280"/>
  <rect x="100" y="280" width="550" height="8" rx="4" fill="#6b7280"/>
  
  <rect x="100" y="310" width="580" height="8" rx="4" fill="#6b7280"/>
  <rect x="100" y="325" width="600" height="8" rx="4" fill="#6b7280"/>
  <rect x="100" y="340" width="520" height="8" rx="4" fill="#6b7280"/>
  
  <!-- AI Badge -->
  <rect x="100" y="370" width="150" height="30" rx="15" fill="#f97316"/>
  <text x="120" y="392" font-family="Arial" font-size="14" fill="white" font-weight="bold">AI PERSONALIZED</text>
  
  <!-- Send Button -->
  <rect x="100" y="420" width="120" height="40" rx="20" fill="#1f2937"/>
  <text x="130" y="445" font-family="Arial" font-size="14" fill="white" font-weight="bold">SEND</text>
  
  <!-- Gmail Logo -->
  <circle cx="650" cy="480" r="25" fill="#f97316" opacity="0.2"/>
  <text x="635" y="490" font-family="Arial" font-size="20" fill="#f97316">📧</text>
  
  <!-- OAuth Badge -->
  <rect x="550" y="460" width="80" height="20" rx="10" fill="#10b981" opacity="0.2"/>
  <text x="560" y="475" font-family="Arial" font-size="10" fill="#10b981" font-weight="bold">OAUTH SECURE</text>
</svg>
